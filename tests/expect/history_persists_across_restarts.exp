#!/usr/bin/env expect
# Executed command history should persist across clean Aish restarts and be
# browsable from history mode in the next session.

set timeout 10
source [file dirname [info script]]/_lib.exp

set home [aish_new_home]
set ::env(AISH_HOME) $home

aish_spawn
aish_send "echo persisted-history-ok"
aish_enter
aish_expect "persisted-history-ok"
aish_wait_prompt
aish_quit

set ::env(AISH_HOME) $home
aish_spawn
aish_send "\t"
aish_expect "\$ "
aish_send "\033\[A"
aish_expect "echo persisted-history-ok"
aish_enter
aish_expect "persisted-history-ok"
aish_wait_prompt

aish_quit
