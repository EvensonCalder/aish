#!/usr/bin/env expect
# Ctrl-X Ctrl-F file picker uses external fzf. If fzf cancels, Aish should show
# a useful message and preserve the current draft unchanged.

set timeout 10
source [file dirname [info script]]/_lib.exp

set bindir "$::env(AISH_EXPECT_ARTIFACT_DIR)/aish-fake-fzf-[pid]-[clock clicks]"
file mkdir $bindir
set fzf "$bindir/fzf"
set fh [open $fzf w]
puts $fh {#!/bin/sh}
puts $fh {cat >/dev/null}
puts $fh {exit 130}
close $fh
file attributes $fzf -permissions 0755
set old_path $::env(PATH)
set ::env(PATH) "$bindir:$old_path"

set workdir "$::env(AISH_EXPECT_ARTIFACT_DIR)/aish-file-picker-[pid]-[clock clicks]"
file mkdir $workdir
set fh [open "$workdir/candidate.txt" w]
puts $fh "candidate"
close $fh

aish_spawn

aish_send "cd $workdir"
aish_enter
aish_wait_prompt

aish_send "echo keep-after-file-picker-cancel"
aish_send "\x18\x06"
aish_expect "file picker cancelled"
aish_expect "> echo keep-after-file-picker-cancel"

aish_enter
aish_expect "keep-after-file-picker-cancel"
aish_wait_prompt

aish_quit

set ::env(PATH) $old_path
file delete -force $bindir
file delete -force $workdir
