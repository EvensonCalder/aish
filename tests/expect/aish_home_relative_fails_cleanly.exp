#!/usr/bin/env expect
# A relative AISH_HOME should fail clearly and must not create state relative to
# the current working directory.

set timeout 10
source [file dirname [info script]]/_lib.exp

set isolated_cwd "$::env(AISH_EXPECT_ARTIFACT_DIR)/aish-relative-aish-home-[pid]-[clock clicks]"
set isolated_home "$::env(AISH_EXPECT_ARTIFACT_DIR)/aish-relative-home-[pid]-[clock clicks]"
file delete -force $isolated_cwd
file delete -force $isolated_home
file mkdir $isolated_cwd
file mkdir $isolated_home
set old_home $::env(HOME)
set old_aish_home_exists [info exists ::env(AISH_HOME)]
if {$old_aish_home_exists} {
    set old_aish_home $::env(AISH_HOME)
}
set ::env(AISH_HOME) "relative-aish"
set ::env(HOME) $isolated_home

spawn -noecho sh -c "cd '$isolated_cwd' && '$::env(AISH_BIN)'"
expect {
    -ex "AISH_HOME must be set to an absolute path" {}
    timeout { puts stderr "no readable relative-AISH_HOME error"; exit 7 }
    eof { puts stderr "eof before relative-AISH_HOME error"; exit 7 }
}

expect {
    eof {}
    -re {> \x1b\[} { puts stderr "unexpected Aish prompt with relative AISH_HOME"; exit 7 }
    timeout { puts stderr "relative-AISH_HOME process did not exit"; exit 7 }
}

if {[file exists "$isolated_cwd/relative-aish"]} {
    puts stderr "unexpected relative AISH_HOME directory created"
    exit 7
}

set ::env(HOME) $old_home
if {$old_aish_home_exists} {
    set ::env(AISH_HOME) $old_aish_home
} else {
    unset -nocomplain ::env(AISH_HOME)
}
file delete -force $isolated_cwd
file delete -force $isolated_home
