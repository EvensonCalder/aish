#!/usr/bin/env expect
# Typing while viewing an AI item should copy it to draft before editing,
# preserving read-only AI mode semantics.

set timeout 10
source [file dirname [info script]]/_lib.exp

set home [aish_new_home]
file mkdir "$home/history"
set fh [open "$home/history/ai.jsonl" w]
puts $fh {{"id":"s1","t":1,"prompt":"expect","ctx":false,"model":"test","items":[{"kind":"command","text":"echo ai-copy"}]}}
close $fh

aish_spawn

aish_send "\t"
aish_expect "\$ "
aish_send "\t"
aish_expect "% "
aish_expect "echo ai-copy"

aish_send "X"
aish_expect "> echo ai-copyX"

aish_send "\x03"
aish_wait_prompt

aish_quit
