#!/usr/bin/env expect
# Production-style event log persistence: without AISH_HOME, event logs should
# be written under $HOME/.aish/logs and readable after restart.

set timeout 10
source [file dirname [info script]]/_lib.exp

set isolated_home "$::env(AISH_EXPECT_ARTIFACT_DIR)/aish-home-log-[pid]-[clock clicks]"
file delete -force $isolated_home
file mkdir $isolated_home
set old_home $::env(HOME)
unset -nocomplain ::env(AISH_HOME)
set ::env(HOME) $isolated_home
set aish_home "$isolated_home/.aish"

aish_spawn_without_aish_home

aish_send "# explain < echo home-log-context"
aish_enter
aish_expect "Run context command? \[Y/n\]"
aish_send "n"
aish_expect "context command skipped: echo home-log-context"
aish_wait_prompt
aish_quit

if {![file exists "$aish_home/logs/events.jsonl"]} {
    puts stderr "missing persisted event log: $aish_home/logs/events.jsonl"
    exit 6
}

aish_spawn_without_aish_home

aish_send "#log 5"
aish_enter
aish_expect "context command skipped"
aish_wait_prompt

aish_quit

set ::env(HOME) $old_home
file delete -force $isolated_home
