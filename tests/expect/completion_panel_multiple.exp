#!/usr/bin/env expect
# Multiple Tab completion candidates should render as a refreshable panel below
# the prompt rather than appending forever.

set timeout 10
source [file dirname [info script]]/_lib.exp

aish_spawn

aish_send "cat Cargo."
aish_send "\t"
aish_expect "file\ttoml"

# The next Tab accepts the inline suggestion instead of refreshing the panel.
aish_send "\t"
aish_expect "> cat Cargo.lock"
aish_send "\x03"
aish_wait_prompt

aish_quit
