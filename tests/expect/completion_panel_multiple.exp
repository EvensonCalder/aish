#!/usr/bin/env expect
# Multiple completion candidates should render as live below-prompt hints while
# typing, then the first Tab should accept the inline suggestion.

set timeout 10
source [file dirname [info script]]/_lib.exp

aish_spawn

aish_send "cat Cargo."
aish_expect "cat Cargo.toml"

aish_send "\t"
aish_expect "> cat Cargo.lock"
aish_send "\x03"
aish_wait_prompt

aish_quit
