# Shared helpers for Aish expect tests.
#
# Sourced by every scenario. Provides:
#   - aish_spawn   : spawn the debug aish binary in an isolated AISH_HOME
#   - aish_expect  : require that a literal substring appears soon
#   - aish_send    : send text to aish, clearing a preserved draft prompt first
#   - aish_enter   : send Enter
#   - aish_quit    : send `exit` + Enter and wait for eof
#   - assert_no    : fail if a forbidden substring appears in recent buffer
#
# All scripts must set `set timeout` themselves before using the helpers.

log_user 0
set ::env(NO_COLOR) "1"
set ::env(TERM) "xterm-256color"
# Expect scenarios create temporary git repositories; do not let a user's global
# commit signing config make those local commits depend on GPG or pinentry.
set ::env(GIT_CONFIG_COUNT) "1"
set ::env(GIT_CONFIG_KEY_0) "commit.gpgsign"
set ::env(GIT_CONFIG_VALUE_0) "false"
set ::aish_last_draft ""

# Pick an isolated AISH_HOME per spawn so concurrent runs do not collide.
proc aish_new_home {} {
    set tmp "/tmp/aish-expect-[pid]-[clock clicks]"
    file mkdir $tmp
    set ::env(AISH_HOME) $tmp
    return $tmp
}

proc aish_spawn {} {
    global spawn_id
    if {![info exists ::env(AISH_HOME)] || $::env(AISH_HOME) eq ""} {
        aish_new_home
    }
    # Force the test binary path; cargo sets CARGO_BIN_EXE_aish when running tests.
    set bin $::env(AISH_BIN)
    spawn -noecho $bin
    aish_wait_prompt
}

proc aish_spawn_without_aish_home {} {
    global spawn_id
    unset -nocomplain ::env(AISH_HOME)
    set bin $::env(AISH_BIN)
    spawn -noecho $bin
    aish_wait_prompt
}

# Wait for the draft prompt, allowing optional restored or multi-line draft
# text before the ANSI cursor-positioning codes.
proc aish_wait_prompt {} {
    expect {
        -re {> ([^\x1b]*)\x1b\[}     { set ::aish_last_draft $expect_out(1,string) }
        timeout            { puts stderr "no prompt"; exit 2 }
        eof                { puts stderr "eof before prompt"; exit 2 }
    }
}

proc aish_expect_blank_prompt {} {
    if {![info exists ::aish_last_draft] || $::aish_last_draft eq ""} {
        return
    }
    puts stderr "expected blank draft prompt, got: $::aish_last_draft"
    exit 6
}

proc aish_expect {needle} {
    expect {
        -ex $needle    {}
        timeout        { puts stderr "expected: $needle"; exit 3 }
        eof            { puts stderr "eof while expecting: $needle"; exit 3 }
    }
}

proc aish_expect_re {pattern} {
    expect {
        -re $pattern   {}
        timeout        { puts stderr "expected re: $pattern"; exit 3 }
        eof            { puts stderr "eof while expecting re: $pattern"; exit 3 }
    }
}

proc aish_expect_template_stored {} {
    expect {
        -re {template stored: (tpl-[0-9a-f]+)} { return $expect_out(1,string) }
        timeout        { puts stderr "expected stored template id"; exit 3 }
        eof            { puts stderr "eof while expecting stored template id"; exit 3 }
    }
}

proc aish_expect_template_replaced {} {
    expect {
        -re {template replaced: tpl-[0-9a-f]+ -> (tpl-[0-9a-f]+)} { return $expect_out(1,string) }
        timeout        { puts stderr "expected replaced template id"; exit 3 }
        eof            { puts stderr "eof while expecting replaced template id"; exit 3 }
    }
}

proc aish_send {text} {
    if {[info exists ::aish_last_draft] && $::aish_last_draft ne ""} {
        send -- "\x03"
        aish_wait_prompt
    }
    send -- $text
    set ::aish_last_draft ""
}

proc aish_enter {} {
    send -- "\r"
}

proc aish_clear_draft {} {
    send -- "\x03"
    aish_wait_prompt
}

proc aish_quit {} {
    aish_clear_draft
    send -- "exit\r"
    expect {
        eof            {}
        timeout        { puts stderr "aish did not exit"; exit 4 }
    }
}

# Assert that a forbidden substring is NOT present until `until` arrives.
# Used to assert e.g. no leaked `dquote>` from bash PS2.
proc assert_no {forbidden until} {
    expect {
        -ex $forbidden { puts stderr "found forbidden: $forbidden"; exit 5 }
        -ex $until     {}
        timeout        { puts stderr "neither forbidden nor expected appeared"; exit 5 }
        eof            { puts stderr "eof while asserting no $forbidden"; exit 5 }
    }
}
