#!/usr/bin/env expect
# Production-style git branch picker cancellation: without AISH_HOME, Ctrl-X
# Ctrl-B should use external fzf, cancel cleanly, and preserve the draft.

set timeout 10
source [file dirname [info script]]/_lib.exp

set isolated_home "$::env(AISH_EXPECT_ARTIFACT_DIR)/aish-home-git-branch-picker-[pid]-[clock clicks]"
file delete -force $isolated_home
file mkdir $isolated_home
set old_home $::env(HOME)
set old_aish_home_exists [info exists ::env(AISH_HOME)]
if {$old_aish_home_exists} {
    set old_aish_home $::env(AISH_HOME)
}
unset -nocomplain ::env(AISH_HOME)
set ::env(HOME) $isolated_home

set bindir "$::env(AISH_EXPECT_ARTIFACT_DIR)/aish-home-branch-fake-fzf-[pid]-[clock clicks]"
file mkdir $bindir
set fzf "$bindir/fzf"
set fh [open $fzf w]
puts $fh {#!/bin/sh}
puts $fh {cat >/dev/null}
puts $fh {exit 130}
close $fh
file attributes $fzf -permissions 0755
set old_path $::env(PATH)
set ::env(PATH) "$bindir:$old_path"

set repo "$::env(AISH_EXPECT_ARTIFACT_DIR)/aish-home-git-branch-work-[pid]-[clock clicks]"
file mkdir $repo

aish_spawn_without_aish_home

aish_send "#completion inline off"
aish_enter
aish_expect "completion.inline=false"
aish_wait_prompt

aish_send "git -C $repo init"
aish_enter
aish_expect_git_init_done
aish_wait_prompt

aish_send "git -C $repo config user.email aish@example.invalid && git -C $repo config user.name Aish && touch $repo/README && git -C $repo add README && git -C $repo commit -m init"
aish_enter
aish_expect "init"
aish_wait_prompt

aish_send "cd $repo"
aish_enter
aish_wait_prompt

aish_send "echo keep-home-after-branch-picker-cancel"
aish_send "\x18\x02"
aish_expect "git branch picker cancelled"
aish_expect "> echo keep-home-after-branch-picker-cancel"

aish_enter
aish_expect "keep-home-after-branch-picker-cancel"
aish_wait_prompt
aish_quit

set ::env(PATH) $old_path
set ::env(HOME) $old_home
if {$old_aish_home_exists} {
    set ::env(AISH_HOME) $old_aish_home
} else {
    unset -nocomplain ::env(AISH_HOME)
}
file delete -force $bindir
file delete -force $repo
file delete -force $isolated_home
