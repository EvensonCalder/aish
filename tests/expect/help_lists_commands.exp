#!/usr/bin/env expect
# `#help` prints grouped command, keybinding, AI, and topic help.

set timeout 10
source [file dirname [info script]]/_lib.exp

aish_spawn

aish_send "#help"
aish_enter

aish_expect "#help"
aish_expect "Aish help"
aish_expect {#help [topic]}
aish_expect "Private commands:"
aish_expect "#status"
aish_expect "#doctor"
aish_expect {#completion [subcommand]}
aish_expect "Keybindings:"
aish_expect "Tab - empty draft cycles modes"
aish_expect "AI and notes:"
aish_expect "# <prompt> - send an AI prompt"
aish_expect "Completion help"
aish_wait_prompt

aish_send "#help completion"
aish_enter

aish_expect "Completion help"
aish_expect "#completion mode auto|tab|off"
aish_expect "#completion display-delay-ms <0-1000>"
aish_expect "#completion tab-accept full|word"
aish_wait_prompt

aish_quit
