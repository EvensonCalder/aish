#!/usr/bin/env expect
# With the legacy inline field disabled, completion runs in Tab mode: the first
# Tab displays the candidate hint and the second Tab accepts it.

set timeout 10
source [file dirname [info script]]/_lib.exp

aish_spawn

aish_send "#completion inline off"
aish_enter
aish_expect "completion.mode=tab"
aish_expect "completion.inline=false"
aish_wait_prompt

aish_send "cat Cargo.t"
aish_send "\t"
aish_expect "> cat Cargo.toml"
aish_send "X"
aish_expect "> cat Cargo.tX"
aish_send "\x03"
aish_wait_prompt

aish_send "cat Cargo.t"
aish_send "\t"
aish_expect "> cat Cargo.toml"
aish_send "\t"
aish_expect "> cat Cargo.toml"
aish_enter
aish_expect "name = \"aish\""
aish_wait_prompt

aish_quit
