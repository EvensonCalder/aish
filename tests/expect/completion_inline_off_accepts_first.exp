#!/usr/bin/env expect
# With inline completion disabled, Tab keeps the legacy direct first-candidate
# acceptance behavior.

set timeout 10
source [file dirname [info script]]/_lib.exp

aish_spawn

aish_send "#completion inline off"
aish_enter
aish_expect "completion.inline=false"
aish_wait_prompt

aish_send "cat Cargo.t"
aish_send "\t"
aish_expect "> cat Cargo.toml"

aish_send "\x03"
aish_wait_prompt

aish_quit
