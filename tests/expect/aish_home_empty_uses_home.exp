#!/usr/bin/env expect
# An empty AISH_HOME should behave like unset and use $HOME/.aish when HOME is
# valid. This avoids a brittle failure from exported-but-empty environment vars.

set timeout 10
source [file dirname [info script]]/_lib.exp

set isolated_home "$::env(AISH_EXPECT_ARTIFACT_DIR)/aish-empty-aish-home-[pid]-[clock clicks]"
file delete -force $isolated_home
file mkdir $isolated_home
set old_home $::env(HOME)
set old_aish_home_exists [info exists ::env(AISH_HOME)]
if {$old_aish_home_exists} {
    set old_aish_home $::env(AISH_HOME)
}
set ::env(AISH_HOME) ""
set ::env(HOME) $isolated_home
set aish_home "$isolated_home/.aish"

spawn -noecho $::env(AISH_BIN)
aish_wait_prompt

aish_send "#doctor"
aish_enter
aish_expect "config_path=$aish_home/config.toml"
aish_expect "events_path=$aish_home/logs/events.jsonl"
aish_wait_prompt

aish_quit

set ::env(HOME) $old_home
if {$old_aish_home_exists} {
    set ::env(AISH_HOME) $old_aish_home
} else {
    unset -nocomplain ::env(AISH_HOME)
}
file delete -force $isolated_home
