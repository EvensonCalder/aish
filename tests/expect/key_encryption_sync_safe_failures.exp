#!/usr/bin/env expect
# Key/encryption/sync commands should report current state and avoid implicit
# shell/git/GPG side effects when required config is missing.

set timeout 10
source [file dirname [info script]]/_lib.exp

aish_spawn

aish_send "#key set"
aish_enter
aish_expect {encryption key is not configured; run #encrypt on <key-fingerprint>}
aish_wait_prompt

aish_send "#key clear"
aish_enter
aish_expect "no stored key to clear"
aish_wait_prompt

aish_send "#encrypt on"
aish_enter
aish_expect {encryption key is not configured; run #encrypt on <key-fingerprint>}
aish_wait_prompt

aish_send "#sync now"
aish_enter
aish_expect "sync remote is not configured; run #set-remote <git-url> first"
aish_wait_prompt

aish_send "#set-remote git@example.invalid:aish.git"
aish_enter
aish_expect "sync.remote=git@example.invalid:aish.git"
aish_expect "no git command run"
aish_wait_prompt

aish_send "#sync"
aish_enter
aish_expect "sync.enabled=false"
aish_expect "sync.remote=git@example.invalid:aish.git"
aish_expect "no git command run"
aish_wait_prompt

aish_send "#sync off"
aish_enter
aish_expect "sync.enabled=false"
aish_expect "no scheduler file created"
aish_wait_prompt

aish_send "#sync ai on"
aish_enter
aish_expect "sync.ai=true"
aish_expect "no git command run"
aish_wait_prompt

aish_send "#sync history on"
aish_enter
aish_expect "sync.history=true"
aish_expect "no git command run"
aish_wait_prompt

aish_send "#sync templates on"
aish_enter
aish_expect "sync.templates=true"
aish_expect "no git command run"
aish_wait_prompt

aish_send "#sync drafts on"
aish_enter
aish_expect "sync.drafts=true"
aish_expect "no git command run"
aish_wait_prompt

aish_send "#sync ai maybe"
aish_enter
aish_expect "usage: #sync ai|history|templates|drafts on|off"
aish_wait_prompt

aish_quit
