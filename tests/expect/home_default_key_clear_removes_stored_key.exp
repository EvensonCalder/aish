#!/usr/bin/env expect
# Production-style key clearing: without AISH_HOME, #key clear should remove
# $HOME/.aish/secrets/key.json.gpg, log the action, and never print secret text.

set timeout 10
source [file dirname [info script]]/_lib.exp

set isolated_home "$::env(AISH_EXPECT_ARTIFACT_DIR)/aish-home-key-clear-[pid]-[clock clicks]"
file delete -force $isolated_home
file mkdir $isolated_home
set old_home $::env(HOME)
set old_aish_home_exists [info exists ::env(AISH_HOME)]
if {$old_aish_home_exists} {
    set old_aish_home $::env(AISH_HOME)
}
unset -nocomplain ::env(AISH_HOME)
set ::env(HOME) $isolated_home
set aish_home "$isolated_home/.aish"

aish_spawn_without_aish_home

set fh [open "$aish_home/secrets/key.json.gpg" w]
puts $fh "encrypted-home-secret-placeholder"
close $fh

aish_send "#key clear"
aish_enter
aish_expect "stored key cleared"
aish_wait_prompt

if {[file exists "$aish_home/secrets/key.json.gpg"]} {
    puts stderr "stored key was not removed from default home"
    exit 6
}

aish_send "#log 5"
aish_enter
aish_expect "stored key cleared"
assert_no "encrypted-home-secret-placeholder" "> "
aish_quit

aish_spawn_without_aish_home
aish_send "#log 5"
aish_enter
aish_expect "stored key cleared"
assert_no "encrypted-home-secret-placeholder" "> "
aish_quit

set ::env(HOME) $old_home
if {$old_aish_home_exists} {
    set ::env(AISH_HOME) $old_aish_home
} else {
    unset -nocomplain ::env(AISH_HOME)
}
file delete -force $isolated_home
