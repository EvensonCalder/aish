#!/usr/bin/env expect
# Placeholder key/encryption/sync commands should report safe no-op behavior and
# must not run shell/git/GPG side effects.

set timeout 10
source [file dirname [info script]]/_lib.exp

aish_spawn

aish_send "#key set"
aish_enter
aish_expect "#key set is not implemented yet; no key stored"
aish_wait_prompt

aish_send "#key clear"
aish_enter
aish_expect "no stored key to clear"
aish_wait_prompt

aish_send "#encrypt on"
aish_enter
aish_expect "warning: existing plaintext data may remain in git history; Aish will not rewrite history automatically"
aish_expect "encryption is not implemented yet; no data changed"
aish_wait_prompt

aish_send "#push"
aish_enter
aish_expect "sync remote is not configured; run #set-remote <git-url> first"
aish_wait_prompt

aish_send "#set-remote git@example.invalid:aish.git"
aish_enter
aish_expect "sync.remote=git@example.invalid:aish.git"
aish_expect "no git command run"
aish_wait_prompt

aish_send "#sync"
aish_enter
aish_expect "sync.enabled=false"
aish_expect "sync.remote=git@example.invalid:aish.git"
aish_expect "no git command run"
aish_wait_prompt

aish_send "#sync off"
aish_enter
aish_expect "sync.enabled=false"
aish_expect "no scheduler file created"
aish_wait_prompt

aish_send "#sync ai on"
aish_enter
aish_expect "sync.ai=true"
aish_expect "no git command run"
aish_wait_prompt

aish_send "#sync history on"
aish_enter
aish_expect "sync.history=true"
aish_expect "no git command run"
aish_wait_prompt

aish_send "#sync templates on"
aish_enter
aish_expect "sync.templates=true"
aish_expect "no git command run"
aish_wait_prompt

aish_send "#sync drafts on"
aish_enter
aish_expect "sync.drafts=true"
aish_expect "no git command run"
aish_wait_prompt

aish_send "#sync ai maybe"
aish_enter
aish_expect "usage: #sync ai|history|templates|drafts on|off"
aish_wait_prompt

aish_quit
