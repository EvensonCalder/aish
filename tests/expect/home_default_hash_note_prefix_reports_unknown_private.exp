#!/usr/bin/env expect
# Production-style default home: comment-like prefixes are not persisted to the
# legacy note file, and unknown private command form is reported.

set timeout 10
source [file dirname [info script]]/_lib.exp

set isolated_home "$::env(AISH_EXPECT_ARTIFACT_DIR)/aish-home-note-prefix-[pid]-[clock clicks]"
file delete -force $isolated_home
file mkdir $isolated_home
set old_home $::env(HOME)
set old_aish_home_exists [info exists ::env(AISH_HOME)]
if {$old_aish_home_exists} {
    set old_aish_home $::env(AISH_HOME)
}
unset -nocomplain ::env(AISH_HOME)
set ::env(HOME) $isolated_home
set aish_home "$isolated_home/.aish"

aish_spawn_without_aish_home

aish_send "#TODO: home hash prefix should not persist"
aish_enter
aish_expect "unknown Aish command: #TODO:"
aish_wait_prompt

aish_send "echo home-hash-prefix-shell-ok"
aish_enter
aish_expect "home-hash-prefix-shell-ok"
aish_wait_prompt

aish_quit

if {[file exists "$aish_home/history/notes.jsonl"]} {
    puts stderr "unexpected persisted notes: $aish_home/history/notes.jsonl"
    exit 6
}

set ::env(HOME) $old_home
if {$old_aish_home_exists} {
    set ::env(AISH_HOME) $old_aish_home
} else {
    unset -nocomplain ::env(AISH_HOME)
}
file delete -force $isolated_home
