#!/usr/bin/env expect
# Production-style history persistence: without AISH_HOME, command history should
# persist under $HOME/.aish and be browsable after restart.

set timeout 10
source [file dirname [info script]]/_lib.exp

set isolated_home "/tmp/aish-home-history-[pid]-[clock clicks]"
file delete -force $isolated_home
file mkdir $isolated_home
set old_home $::env(HOME)
unset -nocomplain ::env(AISH_HOME)
set ::env(HOME) $isolated_home
set aish_home "$isolated_home/.aish"

aish_spawn_without_aish_home
aish_send "echo home-history-ok"
aish_enter
aish_expect "home-history-ok"
aish_wait_prompt
aish_quit

if {![file exists "$aish_home/history/regular.jsonl"]} {
    puts stderr "missing persisted history: $aish_home/history/regular.jsonl"
    exit 6
}

aish_spawn_without_aish_home
aish_send "\t"
aish_expect "\$ "
aish_send "\033\[A"
aish_expect "echo home-history-ok"
aish_enter
aish_expect "home-history-ok"
aish_wait_prompt

aish_quit

set ::env(HOME) $old_home
file delete -force $isolated_home
