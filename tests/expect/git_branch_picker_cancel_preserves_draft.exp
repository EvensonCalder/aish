#!/usr/bin/env expect
# Ctrl-X Ctrl-B git branch picker uses external fzf. If fzf cancels, Aish should
# show a useful message and preserve the current draft unchanged.

set timeout 10
source [file dirname [info script]]/_lib.exp

set bindir "/tmp/aish-fake-fzf-[pid]-[clock clicks]"
file mkdir $bindir
set fzf "$bindir/fzf"
set fh [open $fzf w]
puts $fh {#!/bin/sh}
puts $fh {cat >/dev/null}
puts $fh {exit 130}
close $fh
file attributes $fzf -permissions 0755
set old_path $::env(PATH)
set ::env(PATH) "$bindir:$old_path"

set repo "/tmp/aish-git-branch-picker-[pid]-[clock clicks]"
file mkdir $repo

aish_spawn

aish_send "#completion inline off"
aish_enter
aish_expect "completion.inline=false"
aish_wait_prompt

aish_send "git -C $repo init"
aish_enter
aish_expect_git_init_done
aish_wait_prompt

aish_send "git -C $repo config user.email aish@example.invalid && git -C $repo config user.name Aish && touch $repo/README && git -C $repo add README && git -C $repo commit -m init"
aish_enter
aish_expect "init"
aish_wait_prompt

aish_send "cd $repo"
aish_enter
aish_wait_prompt

aish_send "echo keep-after-branch-picker-cancel"
aish_send "\x18\x02"
aish_expect "git branch picker cancelled"
aish_expect "> echo keep-after-branch-picker-cancel"

aish_enter
aish_expect "keep-after-branch-picker-cancel"
aish_wait_prompt

aish_quit

set ::env(PATH) $old_path
file delete -force $bindir
file delete -force $repo
