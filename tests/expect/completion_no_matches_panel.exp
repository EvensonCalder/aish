#!/usr/bin/env expect
# When draft completion finds no candidates, Aish should keep the prompt quiet
# and leave the draft unchanged.

set timeout 10
source [file dirname [info script]]/_lib.exp

aish_spawn

aish_send "zzzzzz-no-match"
send -- "\t"

send -- "\u001b"
send -- "echo after-completion\r"
assert_no "no completions" "after-completion"
aish_wait_prompt

aish_quit
