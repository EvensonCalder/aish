#!/usr/bin/env expect
# When draft completion finds no candidates, Aish should show the explicit
# "no completions" panel instead of silently doing nothing.

set timeout 10
source [file dirname [info script]]/_lib.exp

aish_spawn

aish_send "zzzzzz-no-match"
send -- "\t"
aish_expect "no completions"

send -- "\u001b"
aish_wait_prompt

aish_quit
