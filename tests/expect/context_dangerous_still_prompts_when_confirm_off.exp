#!/usr/bin/env expect
# Dangerous context commands must still require confirmation even after
# #context confirm off disables the normal prompt for safe commands.

set timeout 10
source [file dirname [info script]]/_lib.exp

set home [aish_new_home]
set marker "$home/dangerous-confirm-off-marker"
set fh [open $marker w]
puts $fh "must remain"
close $fh

aish_spawn

aish_send "#context confirm off"
aish_enter
aish_expect "context.confirm=false"
aish_wait_prompt

aish_send "# explain danger < rm -rf $marker"
aish_enter
aish_expect "dangerous context command requires confirmation: rm -rf $marker"

aish_send "n"
aish_expect "context command skipped: rm -rf $marker"
aish_wait_prompt

aish_quit

if {![file exists $marker]} {
    puts stderr "dangerous context command ran despite refusal with confirm off"
    exit 6
}
