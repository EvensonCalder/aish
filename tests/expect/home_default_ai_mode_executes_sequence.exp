#!/usr/bin/env expect
# Production-style AI history: without AISH_HOME, preloaded AI sessions under
# $HOME/.aish/history/ai.jsonl should be browsable and executable in % mode.

set timeout 10
source [file dirname [info script]]/_lib.exp

set isolated_home "/tmp/aish-home-ai-mode-[pid]-[clock clicks]"
file delete -force $isolated_home
file mkdir $isolated_home
set old_home $::env(HOME)
set old_aish_home_exists [info exists ::env(AISH_HOME)]
if {$old_aish_home_exists} {
    set old_aish_home $::env(AISH_HOME)
}
unset -nocomplain ::env(AISH_HOME)
set ::env(HOME) $isolated_home
set aish_home "$isolated_home/.aish"

aish_spawn_without_aish_home
aish_quit

set fh [open "$aish_home/history/ai.jsonl" w]
puts $fh {{"id":"home-s1","t":1,"prompt":"expect","ctx":false,"model":"test","items":[{"kind":"command","text":"echo home-ai-first"},{"kind":"command","text":"echo home-ai-second"}]}}
close $fh

aish_spawn_without_aish_home

aish_send "#doctor"
aish_enter
aish_expect "ai_sessions=1"
aish_wait_prompt

aish_send "\t"
aish_expect "\$ "
aish_send "\t"
aish_expect "% "
aish_expect "echo home-ai-first"

aish_enter
aish_expect "home-ai-first"
aish_expect "% "
aish_expect "echo home-ai-second"

aish_enter
aish_expect "home-ai-second"
aish_wait_prompt
aish_quit

set ::env(HOME) $old_home
if {$old_aish_home_exists} {
    set ::env(AISH_HOME) $old_aish_home
} else {
    unset -nocomplain ::env(AISH_HOME)
}
file delete -force $isolated_home
