#!/usr/bin/env expect
# Production-style manual sync: without AISH_HOME, #sync now should sync managed
# files from $HOME/.aish to a local bare remote without scheduler files.

set timeout 25
source [file dirname [info script]]/_lib.exp

set root "$::env(AISH_EXPECT_ARTIFACT_DIR)/aish-home-sync-push-[pid]-[clock clicks]"
set isolated_home "$root/user-home"
set aish_home "$isolated_home/.aish"
set remote "$root/remote.git"
file delete -force $root
file mkdir $root
file mkdir $isolated_home
set old_home $::env(HOME)
set old_git_author_name_exists [info exists ::env(GIT_AUTHOR_NAME)]
set old_git_author_email_exists [info exists ::env(GIT_AUTHOR_EMAIL)]
set old_git_committer_name_exists [info exists ::env(GIT_COMMITTER_NAME)]
set old_git_committer_email_exists [info exists ::env(GIT_COMMITTER_EMAIL)]
if {$old_git_author_name_exists} { set old_git_author_name $::env(GIT_AUTHOR_NAME) }
if {$old_git_author_email_exists} { set old_git_author_email $::env(GIT_AUTHOR_EMAIL) }
if {$old_git_committer_name_exists} { set old_git_committer_name $::env(GIT_COMMITTER_NAME) }
if {$old_git_committer_email_exists} { set old_git_committer_email $::env(GIT_COMMITTER_EMAIL) }
set old_aish_home_exists [info exists ::env(AISH_HOME)]
if {$old_aish_home_exists} {
    set old_aish_home $::env(AISH_HOME)
}
unset -nocomplain ::env(AISH_HOME)
set ::env(HOME) $isolated_home
set ::env(GIT_AUTHOR_NAME) "Aish Expect"
set ::env(GIT_AUTHOR_EMAIL) "aish@example.invalid"
set ::env(GIT_COMMITTER_NAME) "Aish Expect"
set ::env(GIT_COMMITTER_EMAIL) "aish@example.invalid"

proc run_git {args} {
    if {[catch {exec git {*}$args 2>@1} output]} {
        puts stderr $output
        exit 6
    }
    return $output
}

run_git init --bare $remote

aish_spawn_without_aish_home

aish_send "#set-remote $remote"
aish_enter
aish_expect "sync.remote=$remote"
aish_wait_prompt

aish_send "#sync history on"
aish_enter
aish_expect "sync.history=true"
aish_wait_prompt

aish_send "echo home-push-history"
aish_enter
aish_expect "home-push-history"
aish_wait_prompt

aish_send "#sync now"
aish_enter
aish_expect "sync started in background"
aish_expect "sync data comparison: history/regular records local=1 remote=0 (local +1)"
aish_expect "sync push completed"
aish_wait_prompt
aish_quit

if {[file exists "$aish_home/cache/runtime/scheduler"]} {
    puts stderr "unexpected scheduler file created by manual default-home sync"
    exit 6
}

set pushed_gitignore [run_git --git-dir $remote show HEAD:.gitignore]
if {[string first "# BEGIN AISH MANAGED" $pushed_gitignore] < 0} {
    puts stderr "remote .gitignore missing managed Aish section after manual default-home sync"
    exit 6
}
set pushed_gitattributes [run_git --git-dir $remote show HEAD:.gitattributes]
if {[string first "merge=union" $pushed_gitattributes] < 0} {
    puts stderr "remote .gitattributes missing Aish union merge rules after manual default-home sync"
    exit 6
}
set pushed_sync_readme [run_git --git-dir $remote show HEAD:README.md]
if {[string first "Aish Sync Repository" $pushed_sync_readme] < 0} {
    puts stderr "remote README.md missing Aish sync notice after manual default-home sync"
    exit 6
}
set pushed_sync_metadata [run_git --git-dir $remote show HEAD:.aish-sync.toml]
if {[string first "history = true" $pushed_sync_metadata] < 0} {
    puts stderr "remote .aish-sync.toml missing sync content metadata after manual default-home sync"
    exit 6
}

set pushed_history [run_git --git-dir $remote show HEAD:history/regular.jsonl]
if {[string first "home-push-history" $pushed_history] < 0} {
    puts stderr "remote history missing manual default-home sync command"
    exit 6
}

set ::env(HOME) $old_home
if {$old_aish_home_exists} {
    set ::env(AISH_HOME) $old_aish_home
} else {
    unset -nocomplain ::env(AISH_HOME)
}
if {$old_git_author_name_exists} { set ::env(GIT_AUTHOR_NAME) $old_git_author_name } else { unset -nocomplain ::env(GIT_AUTHOR_NAME) }
if {$old_git_author_email_exists} { set ::env(GIT_AUTHOR_EMAIL) $old_git_author_email } else { unset -nocomplain ::env(GIT_AUTHOR_EMAIL) }
if {$old_git_committer_name_exists} { set ::env(GIT_COMMITTER_NAME) $old_git_committer_name } else { unset -nocomplain ::env(GIT_COMMITTER_NAME) }
if {$old_git_committer_email_exists} { set ::env(GIT_COMMITTER_EMAIL) $old_git_committer_email } else { unset -nocomplain ::env(GIT_COMMITTER_EMAIL) }
file delete -force $root
