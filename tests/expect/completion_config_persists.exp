#!/usr/bin/env expect
# #completion should persist max-results config and affect the real completion UI.

set timeout 10
source [file dirname [info script]]/_lib.exp

set work "/tmp/aishcc-[pid]"
file mkdir $work
close [open "$work/aish-complete-three.txt" w]
close [open "$work/aish-complete-two.txt" w]

aish_spawn

aish_send "#completion"
aish_enter
aish_expect "completion.enabled=true"
aish_expect "completion.max_results=5"
aish_expect "completion.inline=true"
aish_expect "completion.fuzzy=true"
aish_expect "completion.tab_accept=full"
aish_expect "completion.match_threshold_percent=50"
aish_expect "completion.typo_threshold_percent=80"
aish_wait_prompt

aish_send "#completion off"
aish_enter
aish_expect "completion.enabled=false"
aish_wait_prompt

aish_send "#completion on"
aish_enter
aish_expect "completion.enabled=true"
aish_wait_prompt

aish_send "#completion max 2"
aish_enter
aish_expect "completion.max_results=2"
aish_wait_prompt

aish_send "#completion inline off"
aish_enter
aish_expect "completion.inline=false"
aish_wait_prompt

aish_send "#completion inline on"
aish_enter
aish_expect "completion.inline=true"
aish_wait_prompt

aish_send "#completion fuzzy off"
aish_enter
aish_expect "completion.fuzzy=false"
aish_wait_prompt

aish_send "#completion fuzzy on"
aish_enter
aish_expect "completion.fuzzy=true"
aish_wait_prompt

aish_send "#completion tab-accept word"
aish_enter
aish_expect "completion.tab_accept=word"
aish_wait_prompt

aish_send "#completion tab-accept full"
aish_enter
aish_expect "completion.tab_accept=full"
aish_wait_prompt

aish_send "#completion match-threshold 80"
aish_enter
aish_expect "completion.match_threshold_percent=80"
aish_wait_prompt

aish_send "#completion typo-threshold 85"
aish_enter
aish_expect "completion.typo_threshold_percent=85"
aish_wait_prompt

aish_send "#config"
aish_enter
aish_expect "completion.enabled=true"
aish_expect "completion.max_results=2"
aish_expect "completion.inline=true"
aish_expect "completion.fuzzy=true"
aish_expect "completion.tab_accept=full"
aish_expect "completion.match_threshold_percent=80"
aish_expect "completion.typo_threshold_percent=85"
aish_wait_prompt

aish_send "#completion max 0"
aish_enter
aish_expect "completion max results must be greater than 0"
aish_wait_prompt

aish_send "#config"
aish_enter
aish_expect "completion.enabled=true"
aish_expect "completion.max_results=2"
aish_expect "completion.fuzzy=true"
aish_expect "completion.match_threshold_percent=80"
aish_expect "completion.typo_threshold_percent=85"
aish_wait_prompt

aish_send "cd $work"
aish_enter
aish_wait_prompt

aish_send "cat aish-complete-t"
aish_expect "> cat aish-complete-three.txt"
aish_expect "file\two.txt"
set old_timeout $timeout
set timeout 1
expect {
    -ex "file\three.txt" { puts stderr "inline completion duplicated in candidate panel"; exit 5 }
    timeout {}
    eof { puts stderr "eof while checking completion limit"; exit 5 }
}
set timeout $old_timeout

aish_send "\x03"
aish_wait_prompt

aish_quit

file delete -force $work
