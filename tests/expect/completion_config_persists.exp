#!/usr/bin/env expect
# #completion should persist max-results config and affect the real completion UI.

set timeout 10
source [file dirname [info script]]/_lib.exp

aish_spawn

aish_send "#completion"
aish_enter
aish_expect "completion.max_results=5"
aish_expect "completion.inline=true"
aish_expect "completion.tab_accept=full"
aish_wait_prompt

aish_send "#completion max 2"
aish_enter
aish_expect "completion.max_results=2"
aish_wait_prompt

aish_send "#completion inline off"
aish_enter
aish_expect "completion.inline=false"
aish_wait_prompt

aish_send "#completion inline on"
aish_enter
aish_expect "completion.inline=true"
aish_wait_prompt

aish_send "#completion tab-accept word"
aish_enter
aish_expect "completion.tab_accept=word"
aish_wait_prompt

aish_send "#completion tab-accept full"
aish_enter
aish_expect "completion.tab_accept=full"
aish_wait_prompt

aish_send "#config"
aish_enter
aish_expect "completion.max_results=2"
aish_expect "completion.inline=true"
aish_expect "completion.tab_accept=full"
aish_wait_prompt

aish_send "#completion max 0"
aish_enter
aish_expect "completion max results must be greater than 0"
aish_wait_prompt

aish_send "#config"
aish_enter
aish_expect "completion.max_results=2"
aish_wait_prompt

aish_send "cd /tmp && touch aish-complete-one.txt aish-complete-two.txt aish-complete-three.txt"
aish_enter
aish_wait_prompt

aish_send "cat aish-complete-t"
send -- "\t"
aish_expect "file\three.txt"
set old_timeout $timeout
set timeout 1
expect {
    -ex "file\two.txt" { puts stderr "inline completion duplicated in candidate panel"; exit 5 }
    timeout {}
    eof { puts stderr "eof while checking completion limit"; exit 5 }
}
set timeout $old_timeout

send -- "\u001b"
aish_wait_prompt

aish_quit
