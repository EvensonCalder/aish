#!/usr/bin/env expect
# Production-style AI key reporting: without AISH_HOME, a configured real env key
# should report key source without printing the environment variable name or
# secret value in #status.

set timeout 10
source [file dirname [info script]]/_lib.exp

set isolated_home "$::env(AISH_EXPECT_ARTIFACT_DIR)/aish-home-ai-key-[pid]-[clock clicks]"
file delete -force $isolated_home
file mkdir $isolated_home
set old_home $::env(HOME)
set old_key_exists [info exists ::env(HOME_EXPECT_SECRET_API_KEY)]
if {$old_key_exists} {
    set old_key $::env(HOME_EXPECT_SECRET_API_KEY)
}
set old_aish_home_exists [info exists ::env(AISH_HOME)]
if {$old_aish_home_exists} {
    set old_aish_home $::env(AISH_HOME)
}
unset -nocomplain ::env(AISH_HOME)
set ::env(HOME) $isolated_home
set ::env(HOME_EXPECT_SECRET_API_KEY) "sk-home-secret-should-not-print"

aish_spawn_without_aish_home

aish_send "#env-key HOME_EXPECT_SECRET_API_KEY"
aish_enter
aish_expect "#env-key=HOME_EXPECT_SECRET_API_KEY"
aish_wait_prompt

aish_send "#status"
aish_enter
aish_expect "ai.key_source=env"
assert_no "HOME_EXPECT_SECRET_API_KEY" "keybindings="
aish_wait_prompt

aish_send "#log 20"
aish_enter
assert_no "sk-home-secret-should-not-print" "> "

aish_quit

set ::env(HOME) $old_home
if {$old_key_exists} {
    set ::env(HOME_EXPECT_SECRET_API_KEY) $old_key
} else {
    unset -nocomplain ::env(HOME_EXPECT_SECRET_API_KEY)
}
if {$old_aish_home_exists} {
    set ::env(AISH_HOME) $old_aish_home
} else {
    unset -nocomplain ::env(AISH_HOME)
}
file delete -force $isolated_home
