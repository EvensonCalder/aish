#!/usr/bin/env expect
# Draft Up/Down should browse saved drafts like a draft history. Down on the
# newest draft should open a blank draft for new input.

set timeout 10
source [file dirname [info script]]/_lib.exp

set home [aish_new_home]
set ::env(AISH_HOME) $home

aish_spawn

aish_send "echo first-saved-draft-by-down"
send -- "\033\[B"
aish_wait_prompt

aish_send "echo second-saved-draft-by-down"
send -- "\033\[B"
aish_wait_prompt

send -- "\033\[A"
aish_expect "> echo second-saved-draft-by-down"
send -- "\033\[A"
aish_expect "> echo first-saved-draft-by-down"
send -- "\033\[B"
aish_expect "> echo second-saved-draft-by-down"
send -- "\033\[B"
aish_wait_prompt

aish_send "echo after-new-draft"
aish_enter
aish_expect "after-new-draft"
aish_wait_prompt

set draft_path "$home/history/draft.jsonl"
if {![file exists $draft_path]} {
    puts stderr "draft history was not created"
    exit 5
}
set fh [open $draft_path r]
set draft_json [read $fh]
close $fh
if {[string first "echo first-saved-draft-by-down" $draft_json] < 0} {
    puts stderr "draft history did not contain first saved draft: $draft_json"
    exit 5
}
if {[string first "echo second-saved-draft-by-down" $draft_json] < 0} {
    puts stderr "draft history did not contain second saved draft: $draft_json"
    exit 5
}
if {[string first "echo second-saved-draft-by-downecho after-new-draft" $draft_json] >= 0} {
    puts stderr "new command was appended to stale draft: $draft_json"
    exit 5
}

aish_quit
