#!/usr/bin/env expect
# Production-style encryption placeholder: without AISH_HOME, #encrypt on should
# warn conservatively but must not mutate storage, initialize git, or create
# scheduler files while encryption is still unimplemented.

set timeout 10
source [file dirname [info script]]/_lib.exp

set isolated_home "/tmp/aish-home-encrypt-placeholder-[pid]-[clock clicks]"
file delete -force $isolated_home
file mkdir $isolated_home
set old_home $::env(HOME)
set old_aish_home_exists [info exists ::env(AISH_HOME)]
if {$old_aish_home_exists} {
    set old_aish_home $::env(AISH_HOME)
}
unset -nocomplain ::env(AISH_HOME)
set ::env(HOME) $isolated_home
set aish_home "$isolated_home/.aish"

aish_spawn_without_aish_home

aish_send "echo encrypt-placeholder-history"
aish_enter
aish_expect "encrypt-placeholder-history"
aish_wait_prompt

aish_send "#mt echo encrypt-template-ok"
aish_enter
aish_expect_template_stored
aish_wait_prompt

aish_send "#encrypt on"
aish_enter
aish_expect "warning: existing plaintext data may remain in git history; Aish will not rewrite history automatically"
aish_expect "encryption is not implemented yet; no data changed"
aish_wait_prompt

aish_send "#status"
aish_enter
aish_expect "encryption=off"
aish_wait_prompt

aish_quit

foreach path [list \
    "$aish_home/history/regular.jsonl" \
    "$aish_home/templates/templates.jsonl" \
    "$aish_home/config.toml" \
] {
    if {![file exists $path]} {
        puts stderr "expected plaintext file missing after placeholder encryption: $path"
        exit 6
    }
}

foreach path [list \
    "$aish_home/history/regular.jsonl.gpg" \
    "$aish_home/templates/templates.jsonl.gpg" \
    "$aish_home/config.toml.gpg" \
    "$aish_home/.git" \
    "$aish_home/cache/runtime/scheduler" \
] {
    if {[file exists $path]} {
        puts stderr "unexpected encryption placeholder side effect: $path"
        exit 6
    }
}

aish_spawn_without_aish_home
aish_send "#status"
aish_enter
aish_expect "encryption=off"
aish_wait_prompt
aish_quit

set ::env(HOME) $old_home
if {$old_aish_home_exists} {
    set ::env(AISH_HOME) $old_aish_home
} else {
    unset -nocomplain ::env(AISH_HOME)
}
file delete -force $isolated_home
