#!/usr/bin/env expect
# A persisted non-empty draft should not auto-fill the startup prompt. It should
# remain available through draft history with Up.

set timeout 10
source [file dirname [info script]]/_lib.exp

set home [aish_new_home]
set ::env(AISH_HOME) $home

aish_spawn
aish_quit

set f [open "$home/history/draft.jsonl" a]
puts $f {{"t":1234567890,"text":"echo restored-draft-ok"}}
close $f

set ::env(AISH_HOME) $home
spawn -noecho $::env(AISH_BIN)
aish_wait_prompt
aish_expect_blank_prompt
aish_send "\033\[A"
aish_expect "echo restored-draft-ok"

aish_quit
