#!/usr/bin/env expect
# Context capture should disclose when output is truncated to the configured
# byte limit before the downstream AI request path runs.

set timeout 10
source [file dirname [info script]]/_lib.exp

set ::env(AISH_EXPECT_CONTEXT_KEY) "test-key"

aish_spawn

aish_send "#base-url https://127.0.0.1:1/v1"
aish_enter
aish_expect "#base-url=https://127.0.0.1:1/v1/chat/completions"
aish_wait_prompt

aish_send "#env-key AISH_EXPECT_CONTEXT_KEY"
aish_enter
aish_expect "#env-key=AISH_EXPECT_CONTEXT_KEY"
aish_wait_prompt

aish_send "#context confirm off"
aish_enter
aish_expect "context.confirm=false"
aish_wait_prompt

aish_send "#context 4"
aish_enter
aish_expect "context.max_bytes=4"
aish_wait_prompt

aish_send "# explain truncation < printf 123456789"
aish_enter
aish_expect "context output truncated to 4 bytes"
aish_wait_prompt

aish_send "#log 10"
aish_enter
aish_expect "context command captured output"
aish_expect "context output truncated"
aish_wait_prompt

aish_quit

unset -nocomplain ::env(AISH_EXPECT_CONTEXT_KEY)
