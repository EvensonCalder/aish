#!/usr/bin/env expect
# Template list/show/replace/rm should work end-to-end in a terminal session.

set timeout 10
source [file dirname [info script]]/_lib.exp

aish_spawn

aish_send "#mt deploy echo old-template"
aish_enter
aish_expect "template stored: deploy"
aish_wait_prompt

aish_send "#template list"
aish_enter
aish_expect "deploy"
aish_wait_prompt

aish_send "#template show deploy"
aish_enter
aish_expect "echo old-template"
aish_wait_prompt

aish_send "#template replace deploy echo replaced-template"
aish_enter
aish_expect "template replaced: deploy"
aish_wait_prompt

aish_send "#template show deploy"
aish_enter
aish_expect "echo replaced-template"
aish_wait_prompt

aish_send "#template rm deploy"
aish_enter
aish_expect "template removed: deploy"
aish_wait_prompt

aish_send "#template list"
aish_enter
aish_expect "no templates"
aish_wait_prompt

aish_quit
