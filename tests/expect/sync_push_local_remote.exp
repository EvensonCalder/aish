#!/usr/bin/env expect
# End-to-end manual sync: #sync now should work against a local bare git remote
# without network access or scheduler files.

set timeout 20
source [file dirname [info script]]/_lib.exp

set root "$::env(AISH_EXPECT_ARTIFACT_DIR)/aish-sync-expect-[pid]-[clock clicks]"
set remote "$root/remote.git"
set seed "$root/seed"
set home "$root/aish-home"
file mkdir $root
file mkdir $seed

proc run_git {args} {
    if {[catch {exec git {*}$args 2>@1} output]} {
        puts stderr $output
        exit 6
    }
    return $output
}

run_git init --bare $remote
run_git -C $seed init
run_git -C $seed config user.name "Aish Expect"
run_git -C $seed config user.email "aish@example.invalid"
set fh [open "$seed/.seed" w]
puts $fh "seed"
close $fh
run_git -C $seed add .seed
run_git -C $seed commit -m seed
run_git -C $seed remote add origin $remote
run_git -C $seed push -u origin HEAD
run_git clone $remote $home
run_git -C $home config user.name "Aish Expect"
run_git -C $home config user.email "aish@example.invalid"

set ::env(AISH_HOME) $home
aish_spawn

aish_send "#set-remote $remote"
aish_enter
aish_expect "sync.remote=$remote"
aish_wait_prompt

aish_send "#sync now"
aish_enter
aish_expect "sync step ok: git add -- .aish-sync.toml .gitattributes .gitignore README.md"
aish_expect "sync step ok: git commit"
aish_expect "sync step ok: git fetch"
aish_expect "sync step ok: git merge --no-edit FETCH_HEAD"
aish_expect "sync step ok: git push"
aish_expect "sync push completed"
aish_wait_prompt

aish_quit

set pushed_gitignore [run_git --git-dir $remote show HEAD:.gitignore]
if {[string first "# BEGIN AISH MANAGED" $pushed_gitignore] < 0} {
    puts stderr "remote .gitignore missing managed Aish section"
    exit 6
}
set pushed_gitattributes [run_git --git-dir $remote show HEAD:.gitattributes]
if {[string first "merge=union" $pushed_gitattributes] < 0} {
    puts stderr "remote .gitattributes missing Aish union merge rules"
    exit 6
}
set pushed_sync_readme [run_git --git-dir $remote show HEAD:README.md]
if {[string first "Aish Sync Repository" $pushed_sync_readme] < 0} {
    puts stderr "remote README.md missing Aish sync notice"
    exit 6
}
set pushed_sync_metadata [run_git --git-dir $remote show HEAD:.aish-sync.toml]
if {[string first "enabled = false" $pushed_sync_metadata] < 0} {
    puts stderr "remote .aish-sync.toml missing unencrypted sync metadata"
    exit 6
}
if {[file exists "$home/cache/runtime/scheduler"]} {
    puts stderr "unexpected scheduler file created"
    exit 6
}
