#!/usr/bin/env expect
# Template creation and use should work end-to-end in the terminal.

set timeout 10
source [file dirname [info script]]/_lib.exp

aish_spawn

aish_send "#mt echo template-expect-ok"
aish_enter
set template_id [aish_expect_template_stored]
aish_wait_prompt

aish_send "#template use $template_id"
aish_enter
aish_expect "template copied to draft: $template_id"
aish_expect "echo template-expect-ok"

aish_enter
aish_expect "template-expect-ok"
aish_wait_prompt

aish_quit
