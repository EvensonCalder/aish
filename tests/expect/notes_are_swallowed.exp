#!/usr/bin/env expect
# Line-leading note commands should be stored by Aish and never sent to the
# backend shell.

set timeout 10
source [file dirname [info script]]/_lib.exp

aish_spawn

aish_send "# TODO: remember expect notes"
aish_enter
aish_expect "note stored"
aish_wait_prompt

# The shell should still be healthy, and the note text should not have been
# interpreted by the shell.
aish_send "echo note-shell-ok"
aish_enter
aish_expect "note-shell-ok"
aish_wait_prompt

aish_quit
