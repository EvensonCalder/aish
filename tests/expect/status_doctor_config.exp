#!/usr/bin/env expect
# `#status`, `#doctor`, and `#config` should be useful read-only diagnostics in
# a real terminal session.

set timeout 10
source [file dirname [info script]]/_lib.exp

aish_spawn

aish_send "false"
aish_enter
aish_wait_prompt

aish_send "#status"
aish_enter
aish_expect "Aish status"
aish_expect "mode=>"
aish_expect "last_status=1"
aish_expect "shell="
aish_expect "ai.final_url="
aish_expect "ai.key_source="
aish_expect "encryption=off"
aish_expect "sync.enabled=false"
aish_expect "context.enabled="
aish_expect "completion.enabled="
aish_expect "completion.max_results="
aish_expect "completion.coalesce_ms="
aish_expect "completion.display_delay_ms="
aish_expect "completion.fuzzy="
aish_expect "keybindings="
aish_wait_prompt

aish_send "#doctor"
aish_enter
aish_expect "Aish doctor"
aish_expect "mode=>"
aish_expect "last_status=1"
aish_expect "regular_history_entries="
aish_expect "ai_sessions="
aish_expect "pty=ok"
aish_expect "gpg=not_configured"
aish_expect "git=not_configured"
aish_expect "fzf=external"
aish_expect "editor.resolved="
aish_wait_prompt

aish_send "#config"
aish_enter
aish_expect "Aish config"
aish_expect "shell.backend="
aish_expect "draft.persist="
aish_expect "completion.enabled="
aish_expect "completion.max_results="
aish_expect "completion.coalesce_ms="
aish_expect "completion.display_delay_ms="
aish_expect "completion.fuzzy="
aish_expect "context.enabled="
aish_expect "encryption=off"
aish_expect "sync.enabled=false"
aish_wait_prompt

aish_quit
