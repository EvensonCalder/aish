#!/usr/bin/env expect
# Ctrl-X Ctrl-V environment variable picker uses external fzf. If fzf cancels,
# Aish should show a useful message and preserve the current draft unchanged.

set timeout 10
source [file dirname [info script]]/_lib.exp

set bindir "/tmp/aish-fake-fzf-[pid]-[clock clicks]"
file mkdir $bindir
set fzf "$bindir/fzf"
set fh [open $fzf w]
puts $fh {#!/bin/sh}
puts $fh {cat >/dev/null}
puts $fh {exit 130}
close $fh
file attributes $fzf -permissions 0755
set old_path $::env(PATH)
set ::env(PATH) "$bindir:$old_path"
set ::env(AISH_EXPECT_PICKER_VAR) "available"

aish_spawn

aish_send "echo keep-after-env-picker-cancel"
aish_send "\x18\x16"
aish_expect "environment variable picker cancelled"
aish_expect "> echo keep-after-env-picker-cancel"

aish_enter
aish_expect "keep-after-env-picker-cancel"
aish_wait_prompt

aish_quit

set ::env(PATH) $old_path
unset ::env(AISH_EXPECT_PICKER_VAR)
file delete -force $bindir
