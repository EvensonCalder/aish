#!/usr/bin/env expect
# Production-style first run: without AISH_HOME, Aish should create and use
# $HOME/.aish under an isolated HOME, not the real user home.

set timeout 10
source [file dirname [info script]]/_lib.exp

set isolated_home "/tmp/aish-home-default-[pid]-[clock clicks]"
file delete -force $isolated_home
file mkdir $isolated_home
set old_home $::env(HOME)
unset -nocomplain ::env(AISH_HOME)
set ::env(HOME) $isolated_home
set aish_home "$isolated_home/.aish"

aish_spawn_without_aish_home

if {![file isdirectory $aish_home]} {
    puts stderr "default .aish directory was not created: $aish_home"
    exit 6
}

foreach path [list \
    $aish_home/config.toml \
    $aish_home/history \
    $aish_home/templates \
    $aish_home/secrets \
    $aish_home/logs \
    $aish_home/cache/runtime \
] {
    if {![file exists $path]} {
        puts stderr "missing default-home first-run path: $path"
        exit 6
    }
}

aish_send "#doctor"
aish_enter
aish_expect "Aish doctor"
aish_expect "config_path=$aish_home/config.toml"
aish_expect "events_path=$aish_home/logs/events.jsonl"
aish_wait_prompt

aish_quit

set ::env(HOME) $old_home
file delete -force $isolated_home
